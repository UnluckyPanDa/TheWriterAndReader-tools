#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TWR_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/the-writer-and-reader"
TWR_BIN="$TWR_DATA_DIR/runtime/bin/twr"

if [[ ! -x "$TWR_BIN" ]]; then
  bash "$SCRIPT_DIR/bootstrap.sh" --ensure >/dev/null
fi
exec "$TWR_BIN" "$@"
