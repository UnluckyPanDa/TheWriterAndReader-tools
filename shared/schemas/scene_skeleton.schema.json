{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thewriterandreader.local/schemas/scene_skeleton.schema.json",
  "title": "TWR Chapter Scene Skeleton",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "story_id", "chapter", "scenes"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "story_id": { "type": "string", "minLength": 1 },
    "chapter": { "type": "integer", "minimum": 1 },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_id",
        "purpose",
        "entry_condition",
        "action_sequence",
        "conflict_escalation",
        "emotional_turns",
        "exit_condition"
      ],
      "properties": {
        "scene_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "purpose": { "$ref": "#/$defs/nonEmptyString" },
        "entry_condition": { "$ref": "#/$defs/nonEmptyString" },
        "action_sequence": { "$ref": "#/$defs/nonEmptyStringArray" },
        "conflict_escalation": { "$ref": "#/$defs/nonEmptyStringArray" },
        "emotional_turns": { "$ref": "#/$defs/nonEmptyStringArray" },
        "exit_condition": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}
