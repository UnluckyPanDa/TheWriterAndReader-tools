{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thewriterandreader.local/schemas/relationship_graph.schema.json",
  "title": "TWR relationship graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "characters", "relationships"],
  "properties": {
    "version": { "const": 1 },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "group": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "position": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "z"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "target", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "strength": { "type": "number", "minimum": 0, "maximum": 1 },
          "direction": {
            "type": "string",
            "enum": ["outgoing", "incoming", "bidirectional"]
          },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "visibility": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "start_chapter": { "type": ["integer", "null"], "minimum": 1 },
              "end_chapter": { "type": ["integer", "null"], "minimum": 1 }
            }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
