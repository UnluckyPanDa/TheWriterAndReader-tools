{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thewriterandreader.local/schemas/scene_contract.schema.json",
  "title": "TWR Chapter Scene Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "story_id", "chapter", "scenes"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "story_id": {
      "type": "string",
      "minLength": 1
    },
    "chapter": {
      "type": "integer",
      "minimum": 1
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_id",
        "viewpoint_character",
        "starting_state",
        "immediate_goal",
        "pressure",
        "opposition",
        "change_axes",
        "required_change",
        "physical_setting",
        "active_characters",
        "required_beats",
        "forbidden_reveals",
        "ending_turn"
      ],
      "properties": {
        "scene_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "viewpoint_character": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "starting_state": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "immediate_goal": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "pressure": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "opposition": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "change_axes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "knowledge",
              "emotion",
              "relationship",
              "practical_situation",
              "danger",
              "intention",
              "mystery",
              "access",
              "commitment",
              "reader_expectation"
            ]
          }
        },
        "required_change": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "physical_setting": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "active_characters": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "required_beats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "forbidden_reveals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "ending_turn": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
