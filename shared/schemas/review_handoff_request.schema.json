{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thewriterandreader.local/schemas/review_handoff_request.schema.json",
  "title": "ReviewHandoffRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_type",
    "handoff_id",
    "created_at",
    "story_id",
    "chapter",
    "draft",
    "draft_sha256",
    "review_pack",
    "review_pack_sha256",
    "reviewer_config_sha256",
    "profile_sha256",
    "expected_reviewers",
    "input_fingerprint",
    "execution",
    "request_digest"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "handoff_type": {"type": "string", "const": "review"},
    "handoff_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "story_id": {"type": "string", "minLength": 1},
    "chapter": {"type": "integer", "minimum": 1},
    "draft": {"type": "string", "minLength": 1},
    "draft_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "review_pack": {"type": "string", "minLength": 1},
    "review_pack_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reviewer_config_sha256": {"type": "string", "minLength": 1},
    "profile_sha256": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "expected_reviewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer", "reviewer_id", "can_block_gate"],
        "properties": {
          "layer": {"type": "string", "enum": ["standard", "series", "special"]},
          "reviewer_id": {"type": "string", "minLength": 1},
          "can_block_gate": {"type": "boolean"}
        }
      }
    },
    "input_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["one_active_writer_per_chapter", "apply_mode"],
      "properties": {
        "one_active_writer_per_chapter": {"type": "boolean", "const": true},
        "apply_mode": {"type": "string", "const": "gate_last"}
      }
    },
    "request_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
